print("Testing: Possible Dust Fault in 1 Hour")

run_hybrid_prediction(
    irr=850,
    temp=38,
    dust=70,
    v_oc=20.1,
    v_batt=12.3,
    v_charge=13.4,
    curr=2.4,

    prev_irr=900,
    prev_temp=36,
    prev_curr=3.9
)